---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { resolvePath } from '../utils/navigation';
---

<BaseLayout title="Daniel Rivera | Portafolio de Liderazgo">
  <!-- Presentación principal -->
  <Hero />

  <!-- Sección de Gráfico de Crecimiento -->
  <section class="py-20 container mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-10 text-slate-900 dark:text-white">Mi Crecimiento en Liderazgo</h2>
    <div class="max-w-2xl mx-auto bg-white dark:bg-slate-900 p-6 rounded-3xl shadow-lg border border-slate-200 dark:border-slate-800">
      <canvas id="myChart"></canvas>
    </div>
  </section>
</BaseLayout>

<script>
  // Inicializamos el gráfico cuando la página carga completamente
  document.addEventListener('astro:page-load', () => {
    const ctx = document.getElementById('myChart') as HTMLCanvasElement;
    if (!ctx) return;

    // @ts-ignore - Acceso a la librería Chart cargada en BaseLayout
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: ['Comunicación', 'Equipo', 'Resolución', 'Gestión', 'Creatividad'],
        datasets: [{
          label: 'Nivel de Aprendizaje (%)',
          data: [85, 90, 80, 95, 88],
          backgroundColor: 'rgba(59, 130, 246, 0.6)',
          borderColor: 'rgb(59, 130, 246)',
          borderWidth: 1
        }]
      },
      options: {
        responsive: true,
        scales: {
          y: {
            beginAtZero: true,
            max: 100,
            ticks: {
              color: '#64748b' // Color de los números del eje Y
            }
          },
          x: {
            ticks: {
              color: '#64748b' // Color de las etiquetas del eje X
            }
          }
        },
        plugins: {
          legend: {
            display: false
          }
        }
      }
    });
  });
</script>