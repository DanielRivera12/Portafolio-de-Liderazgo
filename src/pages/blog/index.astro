---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Badge from '../../components/Badge.astro';
import { resolvePath } from '../../utils/navigation';

const posts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

// Sort posts by date descending
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Latest updates, thoughts, and tutorials from the Zenith team.">
  <div class="bg-slate-50 border-b border-slate-200 py-16 md:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4">The Zenith Blog</h1>
      <p class="text-xl text-slate-600">
        Insights, updates, and resources for SaaS founders and indie hackers.
      </p>
    </div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 max-w-5xl">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {posts.map(post => (
        <article class="bg-white border border-slate-200 rounded-2xl overflow-hidden hover:shadow-lg transition-shadow duration-300 flex flex-col">
          <div class="p-8 flex-grow flex flex-col">
            <div class="flex items-center gap-3 mb-4 text-sm text-slate-500">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <span>•</span>
              <span>{post.data.author}</span>
            </div>
            
            <h2 class="text-2xl font-bold text-slate-900 mb-3 hover:text-primary-600 transition-colors">
              <a href={resolvePath(`/blog/${post.id}`)}>{post.data.title}</a>
            </h2>
            
            <p class="text-slate-600 mb-6 flex-grow">
              {post.data.description}
            </p>
            
            <div class="flex flex-wrap gap-2 mt-auto">
              {post.data.tags.map(tag => (
                <Badge variant="neutral">{tag}</Badge>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
