---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { resolvePath } from '../utils/navigation';
---

<BaseLayout title="Get Started" description="Create your Zenix account and start building your SaaS website.">
  <section class="min-h-[calc(100vh-4rem)] bg-white py-16 transition-colors dark:bg-[#09090b] md:py-24">
    <div class="container mx-auto grid max-w-6xl grid-cols-1 items-center gap-12 px-4 sm:px-6 lg:grid-cols-[1fr_460px] lg:px-8">
      <div class="max-w-2xl">
        <p class="mb-4 text-sm font-bold uppercase tracking-widest text-primary-600 dark:text-primary-400">Start with Zenix</p>
        <h1 class="mb-6 font-heading text-4xl font-extrabold leading-tight tracking-tight text-slate-900 dark:text-white md:text-6xl">
          Build from a focused foundation.
        </h1>
        <p class="text-lg leading-8 text-slate-600 dark:text-slate-400">
          Create an account to save your project preferences, compare plans, and keep your launch resources in one place.
        </p>
      </div>

      <div class="glass-panel rounded-2xl p-6 shadow-xl shadow-slate-900/5 dark:shadow-black/20 sm:p-8">
        <h2 class="mb-6 font-heading text-2xl font-bold text-slate-900 dark:text-white">Create account</h2>
        <form class="space-y-5" action={resolvePath('/pricing/')} method="get">
          <div>
            <label for="name" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Name</label>
            <input id="name" name="name" type="text" autocomplete="name" required class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white" placeholder="Your name" />
          </div>
          <div>
            <label for="email" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Email</label>
            <input id="email" name="email" type="email" autocomplete="email" required class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white" placeholder="you@example.com" />
          </div>
          <div>
            <label for="password" class="mb-2 block text-sm font-medium text-slate-700 dark:text-slate-300">Password</label>
            <input id="password" name="password" type="password" autocomplete="new-password" required class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition-colors placeholder:text-slate-400 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 dark:border-slate-700 dark:bg-slate-900 dark:text-white" placeholder="••••••••" />
          </div>
          <Button type="submit" class="w-full">Get Started</Button>
        </form>
        <p class="mt-6 text-center text-sm text-slate-500 dark:text-slate-400">
          Already have an account?
          <a href={resolvePath('/login/')} class="font-medium text-primary-600 hover:text-primary-500 dark:text-primary-400">Sign in</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
