---
import Button from './Button.astro';
import Badge from './Badge.astro';
---

<section class="relative pt-24 pb-32 overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-primary-50 via-white to-white"></div>
  
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="flex justify-center mb-8">
      <Badge variant="primary" class="px-3 py-1 text-sm border border-primary-200">
        <span class="mr-2">🎉</span> v1.0 is now live!
      </Badge>
    </div>
    
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-slate-900 mb-8 max-w-4xl mx-auto">
      Launch your next <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-accent-500">Micro-SaaS</span> in record time.
    </h1>
    
    <p class="text-xl text-slate-600 mb-12 max-w-2xl mx-auto">
      Zenith is the ultimate Astro theme packed with components, sections, and everything you need to convert visitors into paying customers.
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <Button href="/pricing" variant="primary" size="lg" class="w-full sm:w-auto">
        Get Started Now
      </Button>
      <Button href="#features" variant="outline" size="lg" class="w-full sm:w-auto">
        View Features
      </Button>
    </div>

    <!-- Optional Mockup Image Area -->
    <div class="relative mx-auto max-w-5xl">
      <div class="aspect-[16/9] rounded-2xl bg-slate-900 shadow-2xl border border-slate-800 flex items-center justify-center overflow-hidden relative">
        <!-- Add a subtle grid background for the mockup placeholder -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px]"></div>
        <p class="text-slate-500 text-lg relative z-10 font-mono">App Screenshot / Dashboard Mockup</p>
      </div>
      
      <!-- Decorative background blur behind mockup -->
      <div class="absolute -top-12 -left-12 -z-10 w-64 h-64 bg-primary-400 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
      <div class="absolute -bottom-12 -right-12 -z-10 w-64 h-64 bg-accent-400 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
    </div>
  </div>
</section>
