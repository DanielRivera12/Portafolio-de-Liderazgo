---
import Button from './Button.astro';
import Badge from './Badge.astro';
import { resolvePath } from '../utils/navigation';
---

<section class="relative pt-32 pb-32 lg:pt-48 lg:pb-40 overflow-hidden">
  <!-- Complex Animated Background (No tocar, le da el efecto chilero) -->
  <div class="absolute inset-0 -z-10 bg-white dark:bg-[#09090b]">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCI+CjxyZWN0IHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCIgZmlsbD0ibm9uZSI+PC9yZWN0Pgo8Y2lyY2xlIGN4PSIxIiBjeT0iMSIgcj0iMSIgZmlsbD0icmdiYSgwLDAsMCwwLjA1KSI+PC9jaXJjbGU+Cjwvc3ZnPg==')] dark:bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCI+CjxyZWN0IHdpZHRoPSIyNCIgaGVpZ2h0PSIyNCIgZmlsbD0ibm9uZSI+PC9yZWN0Pgo8Y2lyY2xlIGN4PSIxIiBjeT0iMSIgcj0iMSIgZmlsbD0icmdiYSgyNTUsMjU1LDI1NSwwLjA1KSI+PC9jaXJjbGU+Cjwvc3ZnPg==')] [mask-image:linear-gradient(to_bottom,white,transparent)]"></div>
    <div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[800px] h-[600px] bg-primary-400/20 dark:bg-primary-900/30 rounded-full blur-[120px] opacity-80 mix-blend-multiply dark:mix-blend-screen animate-pulse"></div>
    <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3 w-[600px] h-[500px] bg-accent-400/20 dark:bg-accent-900/30 rounded-full blur-[100px] opacity-80 mix-blend-multiply dark:mix-blend-screen"></div>
  </div>
  
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center reveal-on-scroll">
    <div class="flex justify-center mb-8">
      <Badge variant="primary" class="px-4 py-1.5 text-sm border border-primary-200 dark:border-primary-800 backdrop-blur-md bg-white/50 dark:bg-primary-900/50">
        <span class="mr-2">👨‍💻</span> Estudiante UVG - Carné: 242028
      </Badge>
    </div>
    
    <!-- Título Principal -->
    <h1 class="text-6xl sm:text-7xl lg:text-8xl font-heading font-extrabold tracking-tight text-slate-900 dark:text-white mb-8 max-w-5xl mx-auto leading-[1.1]">
      Hola, soy <span class="text-gradient">Daniel Rivera</span>
    </h1>
    
    <!-- Subtítulo / Perfil -->
    <p class="text-xl sm:text-2xl text-slate-600 dark:text-slate-400 mb-6 max-w-3xl mx-auto font-sans leading-relaxed font-semibold">
      Portafolio Académico | Liderazgo y Resolución de Conflictos
    </p>

    <!-- Párrafo de presentación -->
    <p class="text-lg text-slate-500 dark:text-slate-400 mb-12 max-w-4xl mx-auto font-sans leading-relaxed">
      Bienvenido a mi portafolio digital. En este espacio presento mi crecimiento personal, las competencias desarrolladas y las evidencias obtenidas durante el curso de <strong>Liderazgo, Resolución de Conflictos y Trabajo en Equipo</strong>. Aquí reflexiono sobre cómo la comunicación, la empatía y la gestión de personas son habilidades fundamentales tanto para mi vida profesional en el área de tecnología como para mi desarrollo humano.
    </p>
    
    <!-- Botones -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20">
      <Button href={resolvePath('/evidencias/')} variant="primary" size="lg" class="w-full sm:w-auto text-lg px-8 py-4 shadow-xl shadow-primary-500/20">
      Ver Evidencias y PDFs
      </Button>
      <Button href={resolvePath('/reflexion/')} variant="outline" size="lg" class="w-full sm:w-auto text-lg px-8 py-4 bg-white/50 dark:bg-slate-900/50 backdrop-blur-sm">
      Leer mi Reflexión Holística
      </Button>
    </div>

    <!-- Complex Mockup Image Area -->
    <div class="relative mx-auto max-w-6xl reveal-on-scroll" style="transition-delay: 200ms;">
      <div class="aspect-[16/9] rounded-3xl bg-slate-900 dark:bg-[#111116] shadow-2xl border border-slate-800 dark:border-slate-800/80 flex items-center justify-center overflow-hidden relative group hover-glow">
        
        <!-- Mac-style window controls -->
        <div class="absolute top-4 left-4 flex gap-2 z-20">
          <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
        </div>

        <!-- Inner mock grid -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:24px_24px] z-0"></div>
        
        <!-- Carta central del Mockup -->
        <div class="relative z-10 p-8 rounded-2xl glass-panel text-left w-3/4 max-w-2xl transform transition-transform group-hover:scale-[1.02] duration-500 bg-white/10 backdrop-blur-md border border-white/20">
          <h2 class="text-3xl font-heading font-bold text-white mb-2">Mi Stack Tecnológico</h2>
          <p class="text-slate-300 mb-6">Desarrollo, arquitectura y mantenimiento preventivo.</p>
          
          <div class="mt-4 grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div class="flex items-center justify-center h-16 bg-slate-800/80 rounded-xl font-bold text-blue-400">Python / Django</div>
            <div class="flex items-center justify-center h-16 bg-slate-800/80 rounded-xl font-bold text-purple-400">C# / .NET 10</div>
            <div class="flex items-center justify-center h-16 bg-slate-800/80 rounded-xl font-bold text-cyan-400">Flutter</div>
            <div class="flex items-center justify-center h-16 bg-slate-800/80 rounded-xl font-bold text-emerald-400">Supabase</div>
          </div>
        </div>
      </div>
      
      <!-- Decorative background blur behind mockup -->
      <div class="absolute -top-12 -left-12 -z-10 w-96 h-96 bg-primary-500/30 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-[100px]"></div>
      <div class="absolute -bottom-12 -right-12 -z-10 w-96 h-96 bg-accent-500/30 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-[100px]"></div>
    </div>
  </div>
</section>